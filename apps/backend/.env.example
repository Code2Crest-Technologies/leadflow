# Database
# Railway/Neon pooled PostgreSQL recommendation:
# DATABASE_URL should include connection_limit=5, pool_timeout=30, and connect_timeout=15.
DATABASE_URL="postgresql://user:password@localhost:5432/whatsapp_crm"
REDIS_URL="redis://localhost:6379"

# JWT Secrets
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-this-in-production"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# WhatsApp Business API
WHATSAPP_PHONE_ID="your-phone-number-id"
WHATSAPP_BUSINESS_ACCOUNT_ID="your-business-account-id"
WHATSAPP_ACCESS_TOKEN="your-access-token"
WHATSAPP_APP_SECRET="your-app-secret"
WEBHOOK_VERIFY_TOKEN="your-webhook-verify-token"

# Meta Ads API
META_ADS_ACCESS_TOKEN="your-ads-access-token"
META_BUSINESS_ACCOUNT_ID="your-meta-business-account-id"

# Server Configuration
NODE_ENV="development"
PORT="3001"
BACKEND_PUBLIC_URL="http://localhost:3001"
LOG_LEVEL="debug"

# Internal website lead intake
CODE2CREST_LEADFLOW_INTEGRATION_SECRET="replace-with-shared-server-secret"
CODE2CREST_LEADFLOW_COMPANY_ID="code2crest-leadflow-company-id"

# Frontend
FRONTEND_URL="http://localhost:3000"

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@code2crest.com"

# Encryption
ENCRYPTION_KEY="your-32-character-encryption-key-"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# File Upload
MAX_FILE_SIZE="10485760"
ALLOWED_FILE_TYPES="jpg,jpeg,png,pdf,doc,docx,xls,xlsx,zip"
