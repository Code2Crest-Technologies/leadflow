NODE_ENV=production

# App URLs
FRONTEND_URL=https://your-leadflow-domain.com
CORS_ORIGIN=https://your-leadflow-domain.com
BACKEND_PUBLIC_URL=https://lead-flow-backend-production-8976.up.railway.app
NEXT_PUBLIC_API_URL=https://api.your-leadflow-domain.com
NEXT_PUBLIC_SOCKET_URL=https://api.your-leadflow-domain.com

# Code2Crest website -> LeadFlow internal lead intake
CODE2CREST_LEADFLOW_INTEGRATION_SECRET=replace-with-shared-server-secret
CODE2CREST_LEADFLOW_COMPANY_ID=replace-with-code2crest-leadflow-company-id

# Database
# Railway/Neon pooled PostgreSQL recommendation:
# add connection_limit=5, pool_timeout=30, and connect_timeout=15.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/lead_flow?schema=crm_user&connection_limit=5&pool_timeout=30&connect_timeout=15

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
SSO_SECRET=replace-with-unified-portal-sso-secret
JWT_EXPIRY=7d
ENABLE_PUBLIC_SIGNUP=false
CODE2CREST_LEADFLOW_INTEGRATION_SECRET=replace-with-shared-server-secret
CODE2CREST_LEADFLOW_COMPANY_ID=replace-with-code2crest-leadflow-company-id

# Encryption
ENCRYPTION_KEY=replace-with-32-byte-random-key

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@example.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM="LeadFlow <notifications@example.com>"

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20

# Upload limits
UPLOAD_MAX_BODY_SIZE=10mb
COMPANY_LOGO_MAX_BYTES=1048576
COMPANY_SIGNATURE_MAX_BYTES=512000

# Optional integrations - do not commit real secrets
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=
