NODE_ENV=production

# App URLs
FRONTEND_URL=https://your-leadflow-domain.com
CORS_ORIGIN=https://your-leadflow-domain.com
NEXT_PUBLIC_API_URL=https://api.your-leadflow-domain.com
NEXT_PUBLIC_SOCKET_URL=https://api.your-leadflow-domain.com

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/lead_flow?schema=crm_user

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
SSO_SECRET=replace-with-unified-portal-sso-secret
JWT_EXPIRY=7d
ENABLE_PUBLIC_SIGNUP=false

# Encryption
ENCRYPTION_KEY=replace-with-32-byte-random-key

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@example.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM="LeadFlow <notifications@example.com>"

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20

# Upload limits
UPLOAD_MAX_BODY_SIZE=10mb
COMPANY_LOGO_MAX_BYTES=1048576
COMPANY_SIGNATURE_MAX_BYTES=512000

# Optional integrations - do not commit real secrets
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=
